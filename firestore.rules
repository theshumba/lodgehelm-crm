rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // LodgeHelm HQ — single-owner lockdown (2026-07-19). Every read and write requires
    // the owner's UID; anonymous auth is retired. The page stays publicly hosted —
    // these rules are the lock. Call Brain and the CRM CLI use the service-account
    // (admin SDK), which bypasses rules by design.
    function isOwner() {
      return request.auth != null && request.auth.uid == 'W86SC8wFMZdH59PYPVPhIIMSEoj1';
    }
    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
