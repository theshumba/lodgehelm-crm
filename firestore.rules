rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Single-user LodgeHelm CRM. Anonymous-auth user gets full CRUD on leads.
    // NOTE (Phase 2 hardening): anonymous auth means anyone who signs in anonymously
    // could access this data — lock this to a specific owner UID or require real auth
    // before this holds anything sensitive.
    match /leads/{leadId} {
      allow read, write: if request.auth != null;
    }
  }
}
